# Supabase (Vercel + local)
# Public values are exposed to the browser in Next.js.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Storage bucket id for admin video uploads (must match Dashboard / migrations).
NEXT_PUBLIC_SUPABASE_VIDEO_UPLOAD_BUCKET=video-uploads
# Storage bucket id for event flyer uploads (jpg/png/webp).
NEXT_PUBLIC_SUPABASE_EVENT_FLYER_BUCKET=event-flyers
# Optional; derived from NEXT_PUBLIC_SUPABASE_URL if omitted (needed for TUS uploads).
NEXT_PUBLIC_SUPABASE_PROJECT_REF=
NEXT_PUBLIC_ADMIN_EMAIL=

# Server-only key (never expose in client code or NEXT_PUBLIC vars).
# Required for admin video file uploads (signed upload URLs to Storage).
SUPABASE_SERVICE_ROLE_KEY=

# Optional — Mux direct upload + adaptive playback (admin dashboard).
# https://dashboard.mux.com/settings/access-tokens
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
